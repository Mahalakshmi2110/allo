// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String        @id @default(cuid())
  name         String
  sku          String        @unique
  pricePaise   Int
  imageEmoji   String        @default("📦")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  stocks       Stock[]
  reservations Reservation[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  city      String
  createdAt DateTime @default(now())
  stocks    Stock[]
}

// Composite primary key — one row per (product, warehouse) pair.
// `reserved` is the count currently held by PENDING reservations.
// available = total - reserved
model Stock {
  productId   String
  warehouseId String
  total       Int    @default(0)
  reserved    Int    @default(0)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@id([productId, warehouseId])
}

model Reservation {
  id              String            @id @default(cuid())
  productId       String
  warehouseId     String
  quantity        Int
  status          ReservationStatus @default(PENDING)
  expiresAt       DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Idempotency: if set, must be unique — prevents duplicate side-effects on retry
  idempotencyKey  String?           @unique

  product Product @relation(fields: [productId], references: [id])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
}

// Stores pre-computed idempotency responses (status + body) so we can
// replay the exact original HTTP response on retry without re-running logic.
model IdempotencyRecord {
  key          String   @id
  responseBody String
  statusCode   Int
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
}
