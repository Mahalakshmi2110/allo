# .env.example — copy to .env.local and fill in your values

# ── Postgres (Supabase / Neon / Railway) ────────────────────────────────────
# Neon:     postgresql://user:pass@host/db?sslmode=require
# Supabase: postgresql://postgres:pass@db.PROJECT.supabase.co:5432/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ── Redis (Upstash) — optional but recommended for idempotency ──────────────
# Format: rediss://:TOKEN@HOST:PORT
REDIS_URL="rediss://:TOKEN@HOST.upstash.io:6379"

# ── Vercel Cron secret ──────────────────────────────────────────────────────
# Set the same value in Vercel project settings > Environment Variables
# In local dev, any non-empty string works:
CRON_SECRET="change-me-in-production"
